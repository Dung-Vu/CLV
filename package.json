{
  "name": "clv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "ingest:once": "tsx src/jobs/ingestion.job.ts",
    "analyzer:once": "tsx src/jobs/analyzer.job.ts",
    "execution:dry": "tsx src/scripts/run-execution.ts",
    "execution:run": "tsx src/scripts/run-execution.ts --real",
    "agents:run": "tsx src/scripts/run-agents.ts",
    "cleanup:non-deals": "tsx src/scripts/cleanup-non-deals.ts",
    "db:seed": "tsx prisma/seed.ts",
    "cron": "dotenv -e .env -- tsx src/jobs/cron.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@tailwindcss/postcss": "^4.2.2",
    "lucide-react": "^1.7.0",
    "next": "^15.2.4",
    "node-cron": "^3.0.3",
    "openai": "^4.90.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4.2.2",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.1.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.1",
    "vitest-mock-extended": "^3.1.0"
  },
  "overrides": {
    "effect": "^3.20.0"
  }
