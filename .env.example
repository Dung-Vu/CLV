# Database
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/clv"

# AI — OpenAI-compatible API (Bailian/Qwen, OpenAI, Groq, etc.)
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY="sk-..."
AI_MODEL="gpt-4o-mini"
AI_MAX_TOKENS=1000

# App
NODE_ENV="development"
LOG_LEVEL="info"
APP_MODE="clean"

# Feature flags (defaults: safe)
AUTO_CLAIM_ENABLED="false"
EXECUTION_DRY_RUN="true"
CLAIM_EMAIL="your-claim-email@example.com"
# Telegram alerts (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"
